# --- OpenFOAM runtime data (regenerated by cases/*/Allrun) ---------------- #
# Keep only the case *definition* (0/, system/, constant dicts, propeller_mm.stl);
# the mesh, decomposition and solution fields are large and reproducible.
cases/*/processor*/
cases/*/postProcessing/
cases/*/constant/polyMesh/
cases/*/constant/extendedFeatureEdgeMesh/
cases/*/constant/geometry/propeller.stl
cases/*/constant/geometry/*.eMesh
cases/*/log.*
cases/*/*.OpenFOAM
# time directories produced by the solver (keep the "0" initial-condition dir)
cases/*/[1-9]*/
cases/*/0.*/

# --- Python ---------------------------------------------------------------- #
__pycache__/
*.pyc

# --- FreeCAD / editor scratch --------------------------------------------- #
*.FCStd1
*.swp

# --- Autodesk Inventor (native binary; regenerable from scripts) ----------- #
# Keep the STEP (portable, the deliverable); the .ipt and Inventor backups are
# large and reproducible via scripts/caseC_inventor.py.
*.ipt
*.iam
OldVersions/

# --- CFD domain STEPs (large, regenerable via scripts/cfd_domain_inventor.py) #
geometry/*/*_cfd.step

# --- Large CFD result media (animations); keep PNG figures + CSV data --------- #
*.avi
*.vtfx

# --- Autodesk CFD working data (study folders, meshes, solver jobs) --------- #
# Created by Autodesk CFD next to the imported STEP; large, machine-local,
# regenerable by re-running the GUI procedure (reports/11_autodesk_cfd_gui.md).
geometry/*/*.stp
geometry/*/*.cfz
geometry/caseA/caseA/
geometry/caseA/caseA_*/
geometry/caseB/caseB/
geometry/caseB/caseB_*/
geometry/caseC/caseC/
geometry/caseC/caseC_*/
